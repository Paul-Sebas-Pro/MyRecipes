# ──────────────────────────────────────────
#  MyRecipes — variables d'environnement
#  Copier en .env : cp .env.example .env
# ──────────────────────────────────────────

# Base de données
DB_USER=myrecipes
DB_PASSWORD=myrecipes
DB_NAME=myrecipes

# JWT — minimum 32 caractères
# Générer : openssl rand -base64 32
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars

# Ports exposés (optionnel — valeurs par défaut si absent)
API_PORT=3000
FRONTEND_PORT=80

# URL de l'API vue depuis le navigateur (baked-in au build frontend)
VITE_API_URL=http://localhost:3000
