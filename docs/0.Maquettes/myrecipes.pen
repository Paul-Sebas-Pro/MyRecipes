                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "aTeDK",
                          "name": "Step",
                          "fill": "#111827",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "2. Incorporer le poulet et cuire 15 minutes. Ajouter le yaourt et laisser mijoter à feu doux.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "OpBNX",
                          "name": "Step",
                          "fill": "#111827",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "3. Cuire le riz basmati séparément. Superposer riz et poulet en couches dans une grande casserole.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "V5xFP",
                          "name": "Step",
                          "fill": "#111827",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "4. Couvrir et cuire à feu très doux 20 min. Servir chaud garni de coriandre fraîche.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
